{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard"
  ],
  "labels": ["dependencies"],
  "schedule": ["before 9am on monday"],
  "prConcurrentLimit": 5,
  "postUpdateOptions": ["gomodTidy"],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 9am on monday"]
  },
  "packageRules": [
    {
      "description": "Charm / Bubble Tea ecosystem releases in lockstep — one PR",
      "matchManagers": ["gomod"],
      "matchPackageNames": ["charm.land/**", "github.com/charmbracelet/**"],
      "groupName": "charm"
    },
    {
      "description": "Group golang.org/x packages",
      "matchManagers": ["gomod"],
      "matchPackageNames": ["golang.org/x/**"],
      "groupName": "golang.org/x"
    },
    {
      "description": "All GitHub Actions bumps in one PR",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions"
    },
    {
      "description": "Auto-merge low-risk updates once CI is green",
      "matchManagers": ["github-actions", "gomod"],
      "matchUpdateTypes": ["patch", "digest"],
      "automerge": true
    },
    {
      "description": "Keep majors as separate, hand-reviewed PRs",
      "matchUpdateTypes": ["major"],
      "addLabels": ["major-update"]
    }
  ]
}
